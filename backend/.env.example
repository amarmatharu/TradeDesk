# TradeDesk API keys — copy this file to `.env` and fill in your keys.
#   cp backend/.env.example backend/.env
# Keys are read at startup. Never commit the real .env (it's gitignored).

# Anthropic (required — powers all AI agents)
# Get it at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Alpaca PAPER trading keys (required — prices + paper execution)
# Get them at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Broker selection ──────────────────────────────────────────────────────────
# Which broker executes trades: alpaca | webull. Default alpaca (paper, safe).
BROKER=alpaca

# WeBull OpenAPI (optional — REAL-money live broker; App Key + App Secret from
# https://www.webull.com/center#openApiManagement). First use requires a one-time
# approval in the WeBull phone app. WeBull US has NO paper/sandbox.
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_REGION=us
WEBULL_ENV=live
WEBULL_ACCOUNT_ID=            # blank = first account from get_account_list
WEBULL_LIVE_TRADING=false     # HARD GATE: false = preview-only (no real orders)

# Benzinga Pro (optional — real-time news feed)
# https://cloud.benzinga.com
BENZINGA_API_KEY=

# Optional extras
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=
